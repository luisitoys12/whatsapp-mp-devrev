# WhatsApp Business API (Meta)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_token
WA_VERIFY_TOKEN=your_custom_verify_token

# MercadoPago
MP_ACCESS_TOKEN=your_mp_access_token
MP_WEBHOOK_SECRET=your_mp_webhook_secret
MP_NOTIFICATION_URL=https://your-app.fly.dev/webhooks/mercadopago

# DevRev (opcional)
DEVREV_TOKEN=your_devrev_token
DEVREV_ORG_ID=your_org_id

# ── Modo de acceso ─────────────────────────────────────────
# BETA:       ACCESS_MODE=qr
# PRODUCCIÓN: ACCESS_MODE=api
ACCESS_MODE=qr

# API Keys para modo producción (JSON)
# Formato: {"clave_secreta":"nombre_cliente"}
API_KEYS={"sk_live_abc123":"cliente_principal","sk_live_xyz789":"cliente_b"}

# App
PORT=3000
BASE_URL=https://your-app.fly.dev
